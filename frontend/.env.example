# Contract addresses (deploy with /genlayer-cli)
NEXT_PUBLIC_CONTRACT_STUDIONET=0x...
NEXT_PUBLIC_CONTRACT_ASIMOV=0x...
NEXT_PUBLIC_CONTRACT_BRADBURY=0x...

# Which network to use for cron/sync (studionet, asimov, or bradbury)
DEPLOY_NETWORK=studionet

# Server-side wallet for cron job (writes to contract)
PRIVATE_KEY=0x...

# Vercel KV / Upstash Redis
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Vercel cron secret (optional, for production security)
CRON_SECRET=
